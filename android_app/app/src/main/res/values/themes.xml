<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AudioEnhance" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.AudioEnhance.GlassCard">
        <item name="cardBackgroundColor">@color/card_dark</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glass_border</item>
    </style>
</resources>
